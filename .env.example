# OTP Store Gateway - Environment Variables

# App
APP_NAME="OTP Store Gateway"
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Database (PostgreSQL)
DATABASE_URL="postgresql://otp_user:secret@localhost:5432/otp_store?schema=public"

# Session (run: openssl rand -base64 32)
SESSION_SECRET="ganti-dengan-secret-acak-min-32-char-base64"

# OTP Rules (PRD §11.1)
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# Pricing default (credit per OTP)
DEFAULT_SMS_PRICE=1
DEFAULT_WHATSAPP_PRICE=1
DEFAULT_EMAIL_PRICE=1
DEFAULT_VOICE_PRICE=2

# Providers
SMS_PROVIDER="dummy"
WHATSAPP_PROVIDER="dummy"
EMAIL_PROVIDER="dummy"
VOICE_PROVIDER="dummy"

# Rate limit
RATE_LIMIT_PER_API_KEY=60
RATE_LIMIT_PER_PHONE_PER_10MIN=3
RATE_LIMIT_PER_IP=100
