// OTP Store Gateway - Prisma Schema
// Adapted from PRD §10 (Data Model)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// Enums
// =========================
enum UserRole {
  admin
  client
}

enum UserStatus {
  active
  inactive
  suspended
}

enum ClientStatus {
  active
  inactive
  suspended
}

enum ProductType {
  otp_sms
  otp_whatsapp
  otp_bundle
  api_subscription
  dedicated_number
  setup_service
}

enum OrderStatus {
  pending
  waiting_payment
  paid
  approved
  rejected
  expired
  cancelled
}

enum WalletTxType {
  credit
  debit
  adjustment
  refund
}

enum OtpChannel {
  sms
  whatsapp
  email
  voice
}

enum OtpStatus {
  pending
  queued
  sent
  verified
  expired
  failed
  cancelled
}

enum OtpDeliveryStatus {
  queued
  sent
  delivered
  failed
  unknown
}

enum OtpLogEvent {
  created
  queued
  sent
  delivered
  failed
  verified
  expired
  resend
  fallback
}

enum ProviderType {
  sms
  whatsapp
  multi
}

enum DedicatedNumberStatus {
  available
  assigned
  suspended
  released
}

// =========================
// 10.1 users
// =========================
model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  phone           String?
  password        String
  role            UserRole   @default(client)
  status          UserStatus @default(active)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  client     Client?
  auditLogs  AuditLog[]

  @@index([email])
  @@map("users")
}

// =========================
// 10.2 clients
// =========================
model Client {
  id            String       @id @default(cuid())
  userId        String       @unique @map("user_id")
  businessName  String       @map("business_name")
  picName       String?      @map("pic_name")
  businessType  String?      @map("business_type")
  websiteUrl    String?      @map("website_url")
  callbackUrl   String?      @map("callback_url")
  status        ClientStatus @default(active)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet           Wallet?
  orders           Order[]
  apiKeys          ApiKey[]
  otpRequests      OtpRequest[]
  walletTxs        WalletTransaction[]
  dedicatedNumbers DedicatedNumber[]
  inboundMessages  InboundMessage[]
  auditLogs        AuditLog[]

  @@map("clients")
}

// =========================
// 10.3 products
// =========================
model Product {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String?
  type          ProductType
  channel       OtpChannel?
  creditAmount  Int         @default(0) @map("credit_amount")
  price         Decimal     @db.Decimal(12, 2)
  validityDays  Int         @default(30) @map("validity_days")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  orderItems OrderItem[]

  @@index([slug])
  @@index([isActive])
  @@map("products")
}

// =========================
// 10.4 orders
// =========================
model Order {
  id            String      @id @default(cuid())
  clientId      String      @map("client_id")
  orderNumber   String      @unique @map("order_number")
  status        OrderStatus @default(pending)
  subtotal      Decimal     @db.Decimal(12, 2)
  tax           Decimal     @default(0) @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  paymentMethod String?     @map("payment_method")
  paymentProof  String?     @map("payment_proof")
  paidAt        DateTime?   @map("paid_at")
  approvedAt    DateTime?   @map("approved_at")
  rejectedAt    DateTime?   @map("rejected_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  client Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items  OrderItem[]

  @@index([clientId])
  @@index([status])
  @@map("orders")
}

// =========================
// 10.5 order_items
// =========================
model OrderItem {
  id           String   @id @default(cuid())
  orderId      String   @map("order_id")
  productId    String   @map("product_id")
  name         String
  quantity     Int      @default(1)
  price        Decimal  @db.Decimal(12, 2)
  creditAmount Int      @default(0) @map("credit_amount")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// =========================
// 10.6 wallets
// =========================
model Wallet {
  id              String   @id @default(cuid())
  clientId        String   @unique @map("client_id")
  smsCredit       Int      @default(0) @map("sms_credit")
  whatsappCredit  Int      @default(0) @map("whatsapp_credit")
  generalCredit   Int      @default(0) @map("general_credit")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

// =========================
// 10.7 wallet_transactions
// =========================
model WalletTransaction {
  id             String       @id @default(cuid())
  clientId       String       @map("client_id")
  type           WalletTxType
  channel        OtpChannel?
  amount         Int
  balanceBefore  Int          @map("balance_before")
  balanceAfter   Int          @map("balance_after")
  referenceType  String?      @map("reference_type")
  referenceId    String?      @map("reference_id")
  description    String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceType, referenceId])
  @@map("wallet_transactions")
}

// =========================
// 10.8 api_keys
// =========================
model ApiKey {
  id                 String    @id @default(cuid())
  clientId           String    @map("client_id")
  name               String
  keyPrefix          String    @map("key_prefix")
  keyHash            String    @map("key_hash")
  permissions        String?
  rateLimitPerMinute Int       @default(60) @map("rate_limit_per_minute")
  lastUsedAt         DateTime? @map("last_used_at")
  expiresAt          DateTime? @map("expires_at")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  otpRequests OtpRequest[]

  @@index([clientId])
  @@index([keyPrefix])
  @@index([isActive])
  @@map("api_keys")
}

// =========================
// 10.9 otp_requests
// =========================
model OtpRequest {
  id                 String            @id @default(cuid())
  clientId           String            @map("client_id")
  apiKeyId           String?           @map("api_key_id")
  requestId          String            @unique @map("request_id")
  phone              String
  phoneNormalized    String            @map("phone_normalized")
  channel            OtpChannel
  purpose            String
  otpHash            String            @map("otp_hash")
  status             OtpStatus         @default(pending)
  deliveryStatus     OtpDeliveryStatus @default(queued) @map("delivery_status")
  attemptCount       Int               @default(0) @map("attempt_count")
  maxAttempt         Int               @default(3) @map("max_attempt")
  expiredAt          DateTime          @map("expired_at")
  sentAt             DateTime?         @map("sent_at")
  deliveredAt        DateTime?         @map("delivered_at")
  verifiedAt         DateTime?         @map("verified_at")
  providerName       String?           @map("provider_name")
  providerMessageId  String?           @map("provider_message_id")
  providerResponse   Json?             @map("provider_response")
  callbackUrl        String?           @map("callback_url")
  ipAddress          String?           @map("ip_address")
  userAgent          String?           @map("user_agent")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  client Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  apiKey ApiKey?   @relation(fields: [apiKeyId], references: [id])
  logs   OtpLog[]

  @@index([clientId])
  @@index([requestId])
  @@index([phoneNormalized])
  @@index([status])
  @@index([deliveryStatus])
  @@index([createdAt])
  @@index([expiredAt])
  @@index([clientId, phoneNormalized, purpose, status])
  @@map("otp_requests")
}

// =========================
// 10.10 otp_logs
// =========================
model OtpLog {
  id           String      @id @default(cuid())
  otpRequestId String      @map("otp_request_id")
  event        OtpLogEvent
  message      String?
  meta         Json?
  createdAt    DateTime    @default(now()) @map("created_at")

  otpRequest OtpRequest @relation(fields: [otpRequestId], references: [id], onDelete: Cascade)

  @@index([otpRequestId])
  @@index([event])
  @@map("otp_logs")
}

// =========================
// 10.11 provider_settings
// =========================
model ProviderSetting {
  id                   String       @id @default(cuid())
  name                 String       @unique
  type                 ProviderType
  baseUrl              String?      @map("base_url")
  credentialsEncrypted String?      @map("credentials_encrypted")
  isActive             Boolean      @default(true) @map("is_active")
  priority             Int          @default(0)
  config               Json?
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  @@index([type])
  @@index([isActive])
  @@map("provider_settings")
}

// =========================
// 10.12 dedicated_numbers
// =========================
model DedicatedNumber {
  id               String                @id @default(cuid())
  clientId         String?               @map("client_id")
  number           String                @unique
  providerName     String?               @map("provider_name")
  providerNumberId String?               @map("provider_number_id")
  countryCode      String?               @map("country_code")
  capabilities     String?
  status           DedicatedNumberStatus @default(available)
  monthlyFee       Decimal               @default(0) @db.Decimal(12, 2) @map("monthly_fee")
  assignedAt       DateTime?             @map("assigned_at")
  expiresAt        DateTime?             @map("expires_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  client          Client?          @relation(fields: [clientId], references: [id])
  inboundMessages InboundMessage[]

  @@index([clientId])
  @@index([status])
  @@map("dedicated_numbers")
}

// =========================
// 10.13 inbound_messages
// =========================
model InboundMessage {
  id                   String    @id @default(cuid())
  clientId             String?   @map("client_id")
  dedicatedNumberId    String    @map("dedicated_number_id")
  fromNumber           String    @map("from_number")
  toNumber             String    @map("to_number")
  messageBody          String    @map("message_body")
  providerName         String?   @map("provider_name")
  providerMessageId    String?   @unique @map("provider_message_id")
  receivedAt           DateTime  @map("received_at")
  rawPayload           Json?     @map("raw_payload")
  forwardedToClientAt  DateTime? @map("forwarded_to_client_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  client          Client?         @relation(fields: [clientId], references: [id])
  dedicatedNumber DedicatedNumber @relation(fields: [dedicatedNumberId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([dedicatedNumberId])
  @@index([fromNumber])
  @@index([toNumber])
  @@index([receivedAt])
  @@map("inbound_messages")
}

// =========================
// 10.14 audit_logs
// =========================
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  clientId   String?  @map("client_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  @@index([userId])
  @@index([clientId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
